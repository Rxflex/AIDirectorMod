{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["AI Director contributors"],
  "contact": {
    "homepage": "https://modrinth.com/mod/aidirector",
    "sources": "https://github.com/yourname/AIDirector",
    "issues": "https://github.com/yourname/AIDirector/issues"
  },
  "license": "MIT",
  "icon": "assets/aidirector/icon.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "dev.aidirector.fabric.AIDirectorFabric"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "minecraft": "~${minecraft_version}",
    "architectury": ">=13.0.0"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "",
        "modmenu.modrinth": "https://modrinth.com/mod/aidirector"
      }
    }
  }
}
